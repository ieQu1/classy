#!/bin/sh
set -euo pipefail
sname="${1}"
dir="test_data/${sname}"
mkdir -p "${dir}"
ERL_FLAGS="-kernel logger_level notice -kernel prevent_overlapping_partitions false -proto_dist inet_tcp_proxy" \
         rebar3 as demo shell --sname "${sname}" --apps inet_tcp_proxy_dist \
         --eval "application:set_env(classy, table_dir, \"${dir}\"), application:ensure_all_started(classy)."
